# VersionRAG .env template for EDA benchmark
# Copy this file to baselines/versionrag/src/.env and fill in your credentials
# Never commit this file to version control

# =========================================================
# OpenAI (used for LLM generation AND OpenAI embeddings)
# =========================================================
OPENAI_API_KEY=sk-replace-me

# Optional: custom OpenAI-compatible base URL (e.g., local vLLM or DashScope)
# Leave blank to use official OpenAI API
OPENAI_BASE_URL=

# =========================================================
# Groq (alternative LLM provider — change LLM_MODE in constants.py)
# =========================================================
GROQ_API_KEY=your-groq-api-key-here

# =========================================================
# Neo4j Graph Database (required for VersionRAG graph index)
#
# Option A: Local Neo4j instance
#   Install: https://neo4j.com/download/
#   Default URI: bolt://localhost:7687
# =========================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-me

# =========================================================
# Neo4j Aura (cloud, alternative to local)
# =========================================================
# NEO4J_URI_AURA=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME_AURA=neo4j
# NEO4J_PASSWORD_AURA=replace-me
# AURA_INSTANCEID=replace-me
